# ========================================================================
# UPI OFFLINE MESH - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ========================================================================

# ===== DATABASE =====
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://localhost:5432/upi_mesh
DB_USER=upimesh
DB_PASSWORD=changeme123
DB_POOL_SIZE=20
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
JPA_DDL=validate

# ===== REDIS (for distributed idempotency) =====
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme456
REDIS_DB=0

# ===== SECURITY: OAuth2 JWT =====
OAUTH2_ISSUER_URI=https://your-auth-provider.com
OAUTH2_PROVIDER_JWKS_URI=https://your-auth-provider.com/.well-known/jwks.json

# ===== SSL/TLS =====
SSL_KEYSTORE_PATH=/path/to/keystore.p12
SSL_KEYSTORE_PASSWORD=keystorepassword
SSL_KEYSTORE_TYPE=PKCS12

# ===== AWS KMS (for key encryption) =====
AWS_KMS_ENABLED=false
AWS_KMS_REGION=us-east-1
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/12345678-1234-1234-1234-123456789012
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===== CORS Configuration =====
CORS_ALLOWED_ORIGINS=https://frontend.example.com,https://dashboard.example.com

# ===== UPI Mesh Configuration =====
UPI_IDEMPOTENCY_TTL=3600
UPI_PACKET_MAX_AGE=3600

# ===== Monitoring & Logging =====
ENVIRONMENT=production
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_DEMO_UPIMESH=INFO

# ===== Application Settings =====
APP_PORT=8080
SPRING_PROFILES_ACTIVE=production

# ===== H2 Console (DEV ONLY) =====
H2_CONSOLE_ENABLED=false
